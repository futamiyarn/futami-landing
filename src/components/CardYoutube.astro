---
import VideoCard from './VideoCard.astro';
import { single, type YouTube } from '@scripts/yt-grabber';
import youtube from '@data/youtube.json';

interface Props {
	channel_id?: string;
	limit_videos?: number;
	hide_second_on_mobile?: boolean;
}

const { channel_id, limit_videos, hide_second_on_mobile } = Astro.props;

// Fetch data menggunakan script yang kamu sediakan
const yt_data = await single(channel_id ?? youtube.futami.id, limit_videos);
---

{
	yt_data.items.map((item: YouTube, index: number) => (
		<VideoCard
			title={item.title}
			thumbnail={`https://img.youtube.com/vi/${item.id}/mqdefault.jpg`}
			href={item.isShorts ? `https://www.youtube.com/shorts/${item.id}` : `https://www.youtube.com/watch?v=${item.id}`}
			isShorts={item.isShorts}
			class={hide_second_on_mobile && index === 1 ? "hidden md:block" : ""}
		/>
	))
}
