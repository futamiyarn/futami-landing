---
export const prerender = false;

import Layout from '@layouts/Layout.astro';
import Section from '@components/Section.astro';
import Navbar from '@components/Navbar.astro';
import NavbarButton from '@components/NavbarButton.astro';
import Card from '@components/Card.astro';
import others from '@data/others.json';
import affiliates from '@data/affiliates.json';

const { id } = Astro.params;

// Data untuk section Platform
const baTools = others.find((o) => o.nama === 'Blue Archive Tools');
const blogLink = others.find((o) => o.nama === 'Futami Blog');

// Ambil 2 random affiliates
const randomAffiliates = affiliates.sort(() => 0.5 - Math.random()).slice(0, 2);
---

<Layout title={`${id} - Futami`}>
	<Navbar>
		<NavbarButton
			label="Read Blog"
			icon="article"
			href="https://blog.futami.my.id"
		/>
		<NavbarButton
			label="Main YouTube"
			icon="youtube"
			href="https://youtube.com/@futamiid"
		/>
		<NavbarButton
			label="TikTok"
			icon="tiktok"
			href="https://tiktok.com/@futamiid"
		/>
	</Navbar>

	<Section title="Special Content" id="special">
		<div
			class="bg-surface-container-low text-on-surface-variant border-outline-variant flex h-40 w-full items-center justify-center rounded-3xl border-2 border-dashed"
		>
			<span class="text-lg font-medium">Content for {id} placeholder</span>
		</div>
	</Section>

	<Section title="Pages" id="pages">
		{
			baTools && (
				<Card
					title={baTools.nama}
					subtitle={baTools.deskripsi}
					icon={baTools.icon_name}
					href={baTools.url}
				/>
			)
		}
		<Card
			title="Channels"
			subtitle="Videos, shorts, and more"
			icon="video"
			href="/channels"
		/>
		{
			blogLink && (
				<Card
					title={blogLink.nama}
					subtitle={blogLink.deskripsi}
					icon={blogLink.icon_name}
					href={blogLink.url}
				/>
			)
		}
		<Card
			title="Featured Playlists"
			subtitle="Curated video collections"
			icon="playlist"
			href="/channels#featured-playlists"
		/>
		<Card
			title="Community"
			subtitle="Social and community group"
			icon="socials"
			href="/social"
		/>
	</Section>

	<Section title="Support Me" id="support">
		<Card
			title="Donasi"
			subtitle='Direct "free" money'
			icon="coins"
			href="/donate"
		/>
		{
			randomAffiliates.map((item) => (
				<Card
					title={item.nama}
					subtitle={item.deskripsi}
					icon={item.icon_name}
					href={item.url}
				/>
			))
		}
	</Section>
</Layout>
