---
export const prerender = false;

import Layout from '@layouts/Layout.astro';
import Section from '@components/Section.astro';
import Navbar from '@components/Navbar.astro';
import NavbarButton from '@components/NavbarButton.astro';
import Card from '@components/Card.astro';
import BlogCard from '@components/BlogCard.astro';
import CardYoutube from '@components/CardYoutube.astro';
import { Icon } from 'astro-icon/components';
import platforms from '@data/platforms.json';
import others from '@data/others.json';
import affiliates from '@data/affiliates.json';

// KV Caching for Blog Posts
const isDev = import.meta.env.DEV || import.meta.env.IS_DEV === 'true';
let kv: any = undefined;

if (!isDev) {
	try {
		// @ts-ignore
		const { env } = await import('cloudflare:workers');
		kv = env.FTM_KV;
	} catch (e) {
		console.error('Failed to import cloudflare:workers', e);
	}
}

const cacheKey = 'blog_latest_posts';
let cachedBlogData: any[] | null = null;

if (kv) {
	try {
		cachedBlogData = await kv.get(cacheKey, { type: 'json' });
	} catch (e) {
		console.error('Error reading blog cache from KV:', e);
	}
}

let latestPosts: any[] = [];

try {
	const response = await fetch('https://blog.futami.my.id/api/latest.json', {
		signal: AbortSignal.timeout(5000)
	});
	
	if (response.ok) {
		const rawData = await response.json();
		const allPosts = rawData.slice(0, 3);
		
		if (kv) {
			const isDifferent = !cachedBlogData || JSON.stringify(allPosts) !== JSON.stringify(cachedBlogData);
			if (isDifferent && allPosts.length > 0) {
				await kv.put(cacheKey, JSON.stringify(allPosts));
			}
		}
		latestPosts = allPosts;
	} else {
		throw new Error('Failed to fetch blog posts');
	}
} catch (e) {
	console.error('Error fetching blog data, falling back to cache:', e);
	latestPosts = cachedBlogData || [];
}

// Data untuk section Platform
const baTools = others.find((o) => o.nama === 'Blue Archive Tools');
const randomPlaylist = platforms
	.filter((p) => p.icon_name === 'playlist')
	.sort(() => 0.5 - Math.random())[0];
const randomActiveChannel = platforms
	.filter((p) => p.archive === false && p.icon_name !== 'playlist')
	.sort(() => 0.5 - Math.random())[0];

// Ambil 2 random affiliates
const randomAffiliates = affiliates.sort(() => 0.5 - Math.random()).slice(0, 2);
---

<Layout title="Futami - talk about anything">
	<Navbar>
		<NavbarButton label="Video Content" icon="video" href="/channels" />
		<NavbarButton
			label="Read Blog"
			icon="article"
			href="https://blog.futami.my.id"
		/>
		<NavbarButton label="Community Group" icon="socials" href="/social" />
		<NavbarButton label="Finantial Support" icon="wallet" href="/donate" />
	</Navbar>

	<Section title="Latest Updates">
		<CardYoutube limit_videos={1} />
		{
			latestPosts.map((post: any) => (
				<BlogCard
					title={post.title}
					subtitle={post.description}
					href={post.link}
					thumbnail={post.thumbnail}
				/>
			))
		}

		<div slot="action" class="flex gap-4">
			<a
				href="/channels"
				class="btn-action flex items-center"
			>
				Channels <Icon name="arrow-right" class="ml-2 h-4 w-4" />
			</a>
			<a
				href="https://blog.futami.my.id"
				class="btn-action flex items-center"
			>
				Blog <Icon name="arrow-right" class="ml-2 h-4 w-4" />
			</a>
		</div>
	</Section>

	<Section title="Platform">
		{
			baTools && (
				<Card
					title={baTools.nama}
					subtitle={baTools.deskripsi}
					icon={baTools.icon_name}
					href={baTools.url}
				/>
			)
		}
		{
			randomPlaylist && (
				<Card
					title={randomPlaylist.nama}
					subtitle={randomPlaylist.deskripsi}
					icon={randomPlaylist.icon_name}
					href={randomPlaylist.url}
				/>
			)
		}
		{
			randomActiveChannel && (
				<Card
					title={randomActiveChannel.nama}
					subtitle={randomActiveChannel.deskripsi}
					icon={randomActiveChannel.icon_name}
					href={randomActiveChannel.url}
				/>
			)
		}
		<Card
			title="Community"
			subtitle="Social and community group"
			icon="socials"
			href="/social"
		/>
	</Section>

	<Section title="Support Me">
		{
			randomAffiliates.map((item) => (
				<Card
					title={item.nama}
					subtitle={item.deskripsi}
					icon={item.icon_name}
					href={item.url}
				/>
			))
		}
		<Card
			title="Donasi"
			subtitle='Direct "free" money'
			icon="coins"
			href="/donate"
		/>
	</Section>
</Layout>
