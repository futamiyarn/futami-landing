---
import Layout from '@layouts/Layout.astro';
import Section from '@components/Section.astro';
import Card from '@components/Card.astro';
import platforms from '@data/platforms.json';

const categories = [...new Set(platforms.map((item) => item.kategori))];
---

<Layout title="Channels - Futami">
	{
		categories.map((category) => (
			<Section title={category} id={category.toLowerCase().replace(/\s+/g, '-')}>
				{platforms
					.filter((item) => item.kategori === category)
					.map((item) => (
						<Card
							title={item.nama}
							subtitle={item.deskripsi}
							icon={item.icon_name}
							href={item.url}
						/>
					))}
			</Section>
		))
	}
</Layout>
