---
import Layout from '@layouts/Layout.astro';
import Section from '@components/Section.astro';
import Navbar from '@components/Navbar.astro';
import NavbarButton from '@components/NavbarButton.astro';
import Card from '@components/Card.astro';
import platforms from '@data/platforms.json';

const categories = [...new Set(platforms.map((item) => item.kategori))];
---

<Layout title="Platform - Futami">
	<Navbar>
		<NavbarButton label="Platform" icon="content" href="#" />
		<NavbarButton label="Videos" icon="video" href="/platform/videos" />
	</Navbar>

	{
		categories.map((category) => (
			<Section title={category}>
				{platforms
					.filter((item) => item.kategori === category)
					.map((item) => (
						<Card
							title={item.nama}
							subtitle={item.deskripsi}
							icon={item.icon_name}
							href={item.url}
						/>
					))}
			</Section>
		))
	}
</Layout>
